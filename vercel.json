**`.github/workflows/deploy.yml`**
```yaml
name: Auto Deploy to Vercel
on: push
jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Deploy
        uses: BetaHuhn/deploy-to-vercel-action@v1
        with:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          VERCEL_TOKEN: ${{ secrets.VERCEL_TOKEN }}
          VERCEL_ORG_ID: ${{ secrets.VERCEL_ORG_ID }}
```[[__LINK_ICON]](https://github.com/marketplace/actions/vercel-deployment-action?f_link_type=f_linkinlinenote&flow_extra=eyJpbmxpbmVfZGlzcGxheV9wb3NpdGlvbiI6MCwiZG9jX3Bvc2l0aW9uIjowLCJkb2NfaWQiOiIzMDZjMThlNzM0NzRhYTdjLTc0YTE4MmNiZjdhZTc4ZjYifQ%3D%3D "[__LINK_ICON]")

